# =======================================
# Environment Configuration Example
# Copy this file to .env and fill in values
# =======================================

# --- Browser Profile (optional) ---
# Path to your existing Chrome/Chromium profile directory
# This helps bypass TikTok CAPTCHA by using your logged-in session
# Example: C:/Users/YourName/AppData/Local/Google/Chrome/User Data
CHROME_PROFILE_PATH=

# --- Proxy Settings (optional) ---
# Format: http://user:pass@host:port
PROXY_URL=

# --- API Keys (optional, for future extensions) ---
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# --- AI Mode (gemini/groq/auto) ---
AI_MODE=auto

# --- Run Settings ---
# Set to "true" to run browser in headless mode (no UI)
HEADLESS=false

# --- Shazam ---
# Rate limit delay between Shazam requests (seconds)
SHAZAM_DELAY=2.0
